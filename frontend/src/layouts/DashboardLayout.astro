---
import BaseLayout from './BaseLayout.astro';
import type { User } from '@types/user';
import { canAccessAdminCards, canAccessAdminFilters, canAccessSystemAdmin } from '@lib/auth';

interface Props {
  user: User;
}

const { user } = Astro.props;
const pathNorm = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(path: string): boolean {
  const p = path.replace(/\/$/, '') || '/';
  return pathNorm === p;
}

const showContentAdminNav = canAccessAdminCards(user) && canAccessAdminFilters(user);
const showSystemAdminNav = canAccessSystemAdmin(user);
const showAdminNav = showContentAdminNav || showSystemAdminNav;
const pageTitle = import.meta.env.PUBLIC_APP_TITLE ?? 'IATEST';
const initials = user.fullName
  .split(/\s+/)
  .filter(Boolean)
  .map((n) => n[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

---

<BaseLayout title={pageTitle}>
  <header
    class="fixed top-0 w-full z-50 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-xl shadow-[0_8px_24px_rgba(24,28,32,0.04)]"
  >
    <div class="flex items-center justify-between px-6 h-16 w-full max-w-screen-xl mx-auto">
      <div class="flex items-center gap-3">
        <div
          class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center overflow-hidden text-white text-xs font-bold"
        >
          {initials}
        </div>
        <span class="text-xl font-bold tracking-tighter text-blue-800 dark:text-blue-200 font-headline"
          >{import.meta.env.PUBLIC_APP_TITLE}</span
        >
      </div>
      <div class="flex items-center gap-2">
        <button
          id="btn-logout"
          type="button"
          class="text-slate-500 p-2 hover:bg-slate-200/50 rounded-full"
        >
          <span class="material-symbols-outlined">logout</span>
        </button>
      </div>
    </div>
  </header>

  <slot />

  <nav
    class:list={[
      'fixed bottom-6 left-1/2 -translate-x-1/2 w-auto max-w-[min(96vw,100%)] rounded-3xl z-40 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-[0_8px_24px_rgba(24,28,32,0.06)] flex items-stretch justify-center gap-2 sm:gap-3 px-1.5 py-1.5',
      showAdminNav ? 'max-w-3xl' : 'max-w-xs',
    ]}
  >
    <a
      class:list={[
        'flex shrink-0 w-[3.5rem] sm:w-14 flex-col items-center justify-center py-1.5 px-0.5 transition-transform duration-200',
        isActive('/dashboard')
          ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
          : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
      ]}
      href="/dashboard"
    >
      <span class="material-symbols-outlined text-[22px]" data-icon="home">home</span>
      <span class="font-inter text-[10px] font-semibold uppercase tracking-wide text-center leading-tight">Inicio</span>
    </a>
    {showContentAdminNav ? (
      <>
        <a
          class:list={[
            'flex shrink-0 w-[3.5rem] sm:w-14 flex-col items-center justify-center py-1.5 px-0.5 transition-transform duration-200',
            isActive('/admin/cards')
              ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
              : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
          ]}
          href="/admin/cards"
        >
          <span class="material-symbols-outlined text-[22px]">dashboard_customize</span>
          <span class="font-inter text-[10px] font-semibold uppercase tracking-wide text-center leading-tight">Agentes</span>
        </a>
        <a
          class:list={[
            'flex shrink-0 w-[3.5rem] sm:w-14 flex-col items-center justify-center py-1.5 px-0.5 transition-transform duration-200',
            isActive('/admin/filters')
              ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
              : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
          ]}
          href="/admin/filters"
        >
          <span class="material-symbols-outlined text-[22px]">filter_list</span>
          <span class="font-inter text-[10px] font-semibold uppercase tracking-wide text-center leading-tight">Categorías</span>
        </a>
      </>
    ) : null}
    {showSystemAdminNav ? (
      <>
        <a
          class:list={[
            'flex shrink-0 w-[3.5rem] sm:w-14 flex-col items-center justify-center py-1.5 px-0.5 transition-transform duration-200',
            isActive('/admin/interactions')
              ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
              : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
          ]}
          href="/admin/interactions"
        >
          <span class="material-symbols-outlined text-[22px]">manage_history</span>
          <span class="font-inter text-[10px] font-semibold uppercase tracking-wide text-center leading-tight">Usos</span>
        </a>
        <a
          class:list={[
            'flex shrink-0 w-[3.5rem] sm:w-14 flex-col items-center justify-center py-1.5 px-0.5 transition-transform duration-200',
            isActive('/admin/users')
              ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
              : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
          ]}
          href="/admin/users"
        >
          <span class="material-symbols-outlined text-[22px]">group</span>
          <span class="font-inter text-[10px] font-semibold uppercase tracking-wide text-center leading-tight">Usuarios</span>
        </a>
      </>
    ) : null}
    <a
      class:list={[
        'flex shrink-0 w-[3.5rem] sm:w-14 flex-col items-center justify-center py-1.5 px-0.5 transition-transform duration-200',
        isActive('/profile')
          ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
          : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
      ]}
      href="/profile"
    >
      <span class="material-symbols-outlined text-[22px]" data-icon="person">person</span>
      <span class="font-inter text-[10px] font-semibold uppercase tracking-wide text-center leading-tight">Perfil</span>
    </a>
  </nav>
</BaseLayout>

<script is:inline>
  document.getElementById('btn-logout')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
    window.location.href = '/login';
  });
</script>
