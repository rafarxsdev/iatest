---
import BaseLayout from './BaseLayout.astro';
import type { User } from '@types/user';

interface Props {
  user: User;
}

const { user } = Astro.props;
const pathname = Astro.url.pathname;
const pathNorm = pathname.replace(/\/$/, '') || '/';
const isHomeActive = pathNorm === '/dashboard';
const isAdminCardsActive = pathNorm === '/admin/cards';
const isAdminFiltersActive = pathNorm === '/admin/filters';
const showAdminNav = user.role === 'admin';
const pageTitle = import.meta.env.PUBLIC_APP_TITLE ?? 'Dashboard';
const initials = user.fullName
  .split(/\s+/)
  .filter(Boolean)
  .map((n) => n[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

---

<BaseLayout title={pageTitle}>
  <header
    class="fixed top-0 w-full z-50 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-xl shadow-[0_8px_24px_rgba(24,28,32,0.04)]"
  >
    <div class="flex items-center justify-between px-6 h-16 w-full max-w-screen-xl mx-auto">
      <div class="flex items-center gap-3">
        <div
          class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center overflow-hidden text-white text-xs font-bold"
        >
          {initials}
        </div>
        <span class="text-xl font-bold tracking-tighter text-blue-800 dark:text-blue-200 font-headline"
          >{import.meta.env.PUBLIC_APP_TITLE}</span
        >
      </div>
      <div class="flex items-center gap-2">
        <button
          class="transition-all duration-300 ease-in-out active:scale-95 text-slate-500 dark:text-slate-400 p-2 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-full"
        >
          <span class="material-symbols-outlined" data-icon="search">search</span>
        </button>
        <button
          id="btn-logout"
          type="button"
          class="text-slate-500 p-2 hover:bg-slate-200/50 rounded-full"
        >
          <span class="material-symbols-outlined">logout</span>
        </button>
      </div>
    </div>
  </header>

  <slot />

  <nav
    class:list={[
      'fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-md rounded-3xl z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-[0_8px_24px_rgba(24,28,32,0.06)] flex justify-around items-center px-4 py-2',
      showAdminNav ? 'max-w-xl' : '',
    ]}
  >
    <a
      class:list={[
        'flex flex-col items-center justify-center py-2 px-6 transition-transform duration-200',
        isHomeActive
          ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-110'
          : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
      ]}
      href="/dashboard"
    >
      <span class="material-symbols-outlined" data-icon="home">home</span>
      <span class="font-inter text-[11px] font-semibold uppercase tracking-wider">Home</span>
    </a>
    {showAdminNav ? (
      <div class="flex items-center gap-1">
        <a
          class:list={[
            'flex flex-col items-center justify-center py-2 px-4 transition-transform duration-200',
            isAdminCardsActive
              ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
              : 'text-slate-400 dark:text-slate-500 py-2 px-4 hover:text-blue-600 dark:hover:text-blue-400',
          ]}
          href="/admin/cards"
        >
          <span class="material-symbols-outlined">dashboard_customize</span>
          <span class="font-inter text-[11px] font-semibold uppercase tracking-wider">Cards</span>
        </a>
        <a
          class:list={[
            'flex flex-col items-center justify-center py-2 px-4 transition-transform duration-200',
            isAdminFiltersActive
              ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-105'
              : 'text-slate-400 dark:text-slate-500 py-2 px-4 hover:text-blue-600 dark:hover:text-blue-400',
          ]}
          href="/admin/filters"
        >
          <span class="material-symbols-outlined">filter_list</span>
          <span class="font-inter text-[11px] font-semibold uppercase tracking-wider">Filtros</span>
        </a>
      </div>
    ) : null}
    <a
      class:list={[
        'flex flex-col items-center justify-center py-2 px-6 transition-transform duration-200',
        pathNorm === '/profile'
          ? 'bg-blue-600 dark:bg-blue-500 text-white rounded-2xl scale-110'
          : 'text-slate-400 dark:text-slate-500 hover:text-blue-600 dark:hover:text-blue-400',
      ]}
      href="/profile"
    >
      <span class="material-symbols-outlined" data-icon="person">person</span>
      <span class="font-inter text-[11px] font-semibold uppercase tracking-wider">Profile</span>
    </a>
  </nav>
</BaseLayout>

<script is:inline>
  document.getElementById('btn-logout')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
    window.location.href = '/login';
  });
</script>
