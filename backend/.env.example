# Entorno
NODE_ENV=development

# Servidor HTTP
PORT=3000

# Origen permitido para CORS (frontend)
FRONTEND_URL=http://localhost:4321

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
# Puede quedar vacío en desarrollo local sin contraseña
DB_PASSWORD=

# JWT (cookie httpOnly)
JWT_SECRET=
JWT_EXPIRES_IN=60m

# Firma de cookies (cookie-parser)
COOKIE_SECRET=

# Bcrypt
BCRYPT_ROUNDS=12
