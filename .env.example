# =============================================================================
# Raíz del proyecto — copiar a .env y ajustar valores (docker compose / local)
# =============================================================================

# --- PostgreSQL (Docker: servicio postgres; local: tu instancia) ---
POSTGRES_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=cambiar_en_produccion

# --- Backend (.cursorrules) ---
NODE_ENV=production
PORT=3000
# Origen del navegador para CORS (URL pública del frontend)
FRONTEND_URL=http://localhost:4321
# En desarrollo local sin Docker, usar DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
JWT_SECRET=generar_cadena_larga_aleatoria
JWT_EXPIRES_IN=60m
COOKIE_SECRET=otra_cadena_secreta_larga
BCRYPT_ROUNDS=12

# --- Frontend (.cursorrules) ---
# SSR: URL directa al API (Docker: servicio backend; local: localhost:3000)
BACKEND_URL=http://backend:3000
# Navegador: vacío = mismo origen /api (solo con reverse proxy o astro dev). Sin proxy, pon la URL pública del API:
# PUBLIC_BACKEND_URL=http://TU_IP_O_DOMINIO:3000
PUBLIC_BACKEND_URL=
PUBLIC_APP_TITLE=Dashboard
HOST=0.0.0.0
